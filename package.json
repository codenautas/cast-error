{
  "name": "cast-error",
  "description": "cast Error for use in TypeScript in catch clausule",
  "version": "0.1.3",
  "repository": "codenautas/cast-error",
  "files": [
    "lib",
    "doc"
  ],
  "main": "lib/cast-error.js",
  "types": "lib/cast-error.d.ts",
  "scripts": {
    "prepare": "tsc -p src",
    "test": "tsc -p src && tsc -p test && nyc mocha test-bild-local/test",
    "test-ci": "npm test"
  },
  "nyc": {
    "exclude": [
      "test-bild-local"
    ],
    "reporter": [
      "html",
      "lcov",
      "text-summary"
    ]
  },
  "overrides": {
    "diff": ">=8.0.2",
    "serialize-javascript": ">=7.0.0",
    "uuid": ">=14.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.0",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0",
    "qa-control": "^0.6.16",
    "typescript": "^5.9.3"
  },
  "qa-control": {
    "profile": "minimum",
    "run-in": "both",
    "type": "lib",
    "gha": "all"
  }
}
